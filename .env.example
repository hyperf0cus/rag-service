# ── Service ────────────────────────────────────────────────────────────────────
SERVICE_NAME=rag-service
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Embeddings provider ────────────────────────────────────────────────────────
# "local"  – sentence-transformers on CPU, no API key needed (default)
# "openai" – OpenAI Embeddings API, requires OPENAI_API_KEY below
EMBEDDINGS_PROVIDER=local
# HuggingFace model ID for local provider (~90 MB, downloaded on first run)
EMBEDDINGS_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LLM provider ───────────────────────────────────────────────────────────────
# "ollama"  – local Ollama server, no API key needed (recommended for local dev)
# "openai"  – OpenAI Chat API, requires OPENAI_API_KEY below
LLM_PROVIDER=ollama

# ── Ollama ─────────────────────────────────────────────────────────────────────
# In Docker Compose the Ollama service is reachable at http://ollama:11434.
# For local dev outside Docker use http://localhost:11434.
OLLAMA_BASE_URL=http://ollama:11434
# Pull the model before first use:
#   docker exec -it rag-service-ollama-1 ollama pull qwen2.5:7b-instruct
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TEMPERATURE=0.2

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Required ONLY when LLM_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Must match model native dimension (1536 for text-embedding-3-small)
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.0

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# Leave blank for unauthenticated local Qdrant
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_chunks

# ── RAG Parameters ─────────────────────────────────────────────────────────────
# Token count per chunk (uses tiktoken cl100k_base)
CHUNK_SIZE=512
# Token overlap between consecutive chunks
CHUNK_OVERLAP=64
# Default top-k for retrieval
RETRIEVAL_TOP_K=5
# Chunks below this cosine similarity score are discarded
SIMILARITY_THRESHOLD=0.30
# Number of texts embedded per API/model call
EMBEDDING_BATCH_SIZE=64
# Max entries in the in-process embedding LRU cache
EMBEDDING_CACHE_MAX_SIZE=10000

# ── Feedback ───────────────────────────────────────────────────────────────────
FEEDBACK_LOG_PATH=data/feedback.jsonl
